rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated or project name slug
    // Fields:
    //   - projectName: string (required)
    //   - story: string (required)
    //   - visualAnchor: string
    //   - seed: number
    //   - scenes: list (required)
    //   - createdAt: timestamp (required)
    //   - imagesDeleted: bool
    //   - ownerUid: string (required)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidProject(data) {
      return data.projectName is string && data.projectName.size() > 0 &&
             data.story is string && data.story.size() > 0 &&
             data.scenes is list &&
             data.createdAt is timestamp;
    }

    match /projects/{projectId} {
      // Allow reading if authenticated (or we could make it public if requested, but sticking to secure default)
      allow read: if isAuthenticated();
      
      // Allow creation if authenticated and data is valid
      allow create: if isAuthenticated() && 
                      isValidProject(request.resource.data) &&
                      request.resource.data.ownerUid == request.auth.uid;
      
      // Allow update only by owner
      allow update: if isOwner(resource.data.ownerUid) && 
                      isValidProject(request.resource.data) &&
                      request.resource.data.ownerUid == resource.data.ownerUid;
      
      allow delete: if isOwner(resource.data.ownerUid);
    }
  }
}
