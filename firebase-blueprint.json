{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A Zyntros video production project",
      "type": "object",
      "properties": {
        "projectName": {
          "type": "string",
          "description": "Unique name for the project to load it later"
        },
        "story": {
          "type": "string",
          "description": "The original narrative input"
        },
        "visualAnchor": {
          "type": "string",
          "description": "The consistent character description"
        },
        "seed": {
          "type": "number",
          "description": "The random seed used for generation"
        },
        "scenes": {
          "type": "array",
          "description": "List of scenes in the project"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was saved"
        },
        "imagesDeleted": {
          "type": "boolean",
          "description": "Whether the images have been auto-deleted after 7 days"
        }
      },
      "required": ["projectName", "story", "scenes", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of saved video projects"
    }
  }
}
